    log_action(db, current_user.username, current_user.role, "Group Member Added",
               "Group", group_name, f"Added {username} to {group_name}", "Success" if result else "Failed", request.client.host)
    return {"success": result}

@app.delete("/api/groups/{group_name}/members/{username}")
async def remove_member(group_name: str, username: str, request: Request,
                        current_user: AppUser = Depends(get_current_user),
                        db: Session = Depends(get_db)):
    """Remove a user from a group"""
    if current_user.role not in ["Admin", "Helpdesk"]:
        raise HTTPException(status_code=403, detail="Insufficient permissions")
    result = ad_service.remove_from_group(username, group_name)
    log_action(db, current_user.username, current_user.role, "Group Member Removed",
               "Group", group_name, f"Removed {username} from {group_name}", "Success" if result else "Failed", request.client.host)
    return {"success": result}

